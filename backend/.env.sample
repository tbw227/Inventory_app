# PostgreSQL (required).
# Local (docker-compose): same URL for both.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/firetrack
# DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/firetrack
#
# Supabase — IPv4: use Session pooler for DATABASE_URL; keep Direct for DIRECT_URL (Prisma migrations).
# Session pooler allows limited concurrent sessions (~15). Prisma must use a tiny pool:
# DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=60
# DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/firetrack
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/firetrack
#
# After setting DATABASE_URL, from backend/:  npx prisma migrate deploy
# SQL mirror: supabase/migrations/ (for Supabase SQL editor or supabase db push)
#
# Optional — Supabase dashboard → Settings → API (for Storage, Edge Functions, or service-role SDK)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
# Comma-separated browser origins allowed by CORS (required in production — server will not start without at least one).
# Comma-separated if you use multiple dev URLs (e.g. Vite on 5174)
FRONTEND_URL=http://localhost:5173,http://localhost:5174
NODE_ENV=development
PORT=5000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
# Throttle POST /auth/login per IP (applies to /api/v1/auth and legacy /api/auth).
# AUTH_LOGIN_WINDOW_MS=900000
# AUTH_LOGIN_MAX_ATTEMPTS=25
# Throttle POST /auth/forgot-password and /auth/reset-password per IP.
# AUTH_RESET_WINDOW_MS=900000
# AUTH_RESET_MAX_ATTEMPTS=5
# Expose Swagger UI at /api/docs in production (default: off). Dev/staging serve docs automatically when NODE_ENV is not production.
# ENABLE_API_DOCS=false

# Dashboard GET /api/dashboard — in-memory cache TTL (ms). 0 = disabled (recommended when running multiple API replicas).
# Single process: default 20000 reduces duplicate heavy queries (e.g. React StrictMode). Not shared across instances.
# DASHBOARD_CACHE_TTL_MS=20000

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_FROM=no-reply@firetrack.com

# Optional: Sentry error tracking (leave empty to disable)
SENTRY_DSN=

# Stripe payment processing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription Checkout (Price IDs from Stripe Dashboard → Products → Prices)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
# Set to true to block API access when company subscription_status is cancelled / past_due / incomplete
SUBSCRIPTION_ENFORCE=false

# OpenWeather (optional). If missing or invalid (401), the app uses Open-Meteo (no key).
OPENWEATHER_API_KEY=
# Use "City,ST,US" when you need a specific US state (e.g. Olathe,KS,US). "City,US" uses geocoder + US filter.
DEFAULT_WEATHER_CITY=Olathe,KS,US
# Per-city forecast cache (seconds). Keeps OpenWeather free-tier calls low for multi-location tenants.
WEATHER_CACHE_TTL_SEC=600
# GNews (optional) — US top headlines when set; merged with free BBC world RSS when you want more items. Key stays on server only.
GNEWS_API_KEY=
# For heavier scale, swap in-memory cache above for Redis in front of getForecast (not wired by default).

# The Weather Company / IBM v3 (optional). Enables /api/weather/twc for lat/lon bundles.
# Do not expose this key in the frontend — use the proxy endpoint only.
WEATHER_COMPANY_API_KEY=

# QuickBooks (optional) — set QUICKBOOKS_ENABLED=true when invoice sync from webhooks is wired
QUICKBOOKS_ENABLED=false
QUICKBOOKS_REALM_ID=

# QuickBooks Online OAuth (Intuit) — redirect URI must match your Intuit app (e.g. http://localhost:5000/api/integrations/quickbooks/callback)
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=http://localhost:5000/api/integrations/quickbooks/callback
# sandbox | production
INTUIT_ENVIRONMENT=sandbox
