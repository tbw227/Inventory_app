# API base (empty = same origin + Vite /api proxy in dev)
VITE_API_URL=

# Stripe.js (Job Detail card payments). Use pk_test_… for local HTTP; pk_live_… needs HTTPS (except localhost).
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Supabase (Project Settings → API). Optional until you use Supabase client features.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override Vite dev server port (default 5174 in vite.config)
# VITE_DEV_PORT=5174
